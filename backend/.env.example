# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here

# JWT Secret (generate a random string)
JWT_SECRET=your-super-secret-jwt-key-make-it-long-and-random

# Server Configuration
NODE_ENV=development
PORT=10000

# Automatic bank-transfer payments
# Configure these on the backend service only.
AUTO_PAYMENT_WEBHOOK_SECRET=change-this-to-a-long-random-secret
AUTO_PAYMENT_PREFIX=FSI
AUTO_PAYMENT_BANK_ID=970432
AUTO_PAYMENT_ACCOUNT_NO=your-bank-account-number
AUTO_PAYMENT_ACCOUNT_NAME=YOUR ACCOUNT NAME
AUTO_PAYMENT_QR_TEMPLATE=compact2

# Instructions:
# 1. Copy this file to .env
# 2. Replace the values with your actual Supabase credentials
# 3. Get credentials from: https://supabase.com/dashboard → Your Project → Settings → API
